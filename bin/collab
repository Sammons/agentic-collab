#!/usr/bin/env node

/**
 * collab — CLI for agentic-collab orchestrator.
 *
 * Auto-discovers orchestrator URL and shared secret.
 * Designed to be used by agents inside tmux sessions or by humans on the host.
 *
 * Environment variables (all optional — auto-discovery handles the common case):
 *   ORCHESTRATOR_URL        — Override orchestrator URL
 *   ORCHESTRATOR_SECRET     — Override secret
 *   ORCHESTRATOR_SECRET_FILE — Override secret file path
 *   COLLAB_AGENT            — Default agent name for send/reply (set by orchestrator)
 */

import { readFileSync, existsSync, mkdtempSync, writeFileSync, readdirSync, renameSync, mkdirSync } from 'node:fs';
import { basename, dirname, join, resolve } from 'node:path';
import { homedir, tmpdir } from 'node:os';
import { execSync } from 'node:child_process';

// ── Mode Detection ──
//
// v3 Q7: the CLI is mode-aware. An "ephemeral" agent runs once per message
// inside a topic-spawned worktree+tmux session. The orchestrator sets a
// specific env trio (MESSAGE_ID + AGENT_TEMPLATE + REPLY_PATH) before pasting
// the `start` hook. We require ALL THREE to flip into ephemeral mode —
// accidental partial leakage from a parent shell must not switch a persistent
// agent's CLI mode.

function isEphemeralMode() {
  return Boolean(
    process.env['MESSAGE_ID']
    && process.env['AGENT_TEMPLATE']
    && process.env['REPLY_PATH'],
  );
}

// ── Config Resolution ──

const CONFIG_DIR = process.env['AGENTIC_COLLAB_CONFIG_DIR']
  ?? join(homedir(), '.config', 'agentic-collab');

function resolveSecret() {
  const env = process.env['ORCHESTRATOR_SECRET'];
  if (env !== undefined) return env || null;

  const file = process.env['ORCHESTRATOR_SECRET_FILE'];
  if (file) {
    try { return readFileSync(file, 'utf-8').trim() || null; } catch { return null; }
  }

  try {
    return readFileSync(join(CONFIG_DIR, 'secret'), 'utf-8').trim() || null;
  } catch { return null; }
}

function discoverViaDocker() {
  try {
    const raw = execSync(
      'docker ps --filter "label=io.agentic-collab.role=orchestrator" --format "{{.Ports}}"',
      { timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] },
    ).toString().trim();
    if (!raw) return null;
    const match = raw.match(/(?:\d+\.\d+\.\d+\.\d+|::):(\d+)->/);
    if (match) return `http://localhost:${match[1]}`;
  } catch {}
  return null;
}

async function discoverOrchestrator() {
  const env = process.env['ORCHESTRATOR_URL'];
  if (env) return env;

  const docker = discoverViaDocker();
  if (docker) {
    try {
      const r = await fetch(`${docker}/api/orchestrator/status`, { signal: AbortSignal.timeout(3000) });
      if (r.ok) return docker;
    } catch {}
  }

  for (const port of [3000, 3001]) {
    const url = `http://localhost:${port}`;
    try {
      const r = await fetch(`${url}/api/orchestrator/status`, { signal: AbortSignal.timeout(3000) });
      if (r.ok) return url;
    } catch {}
  }

  return null;
}

// ── HTTP Helpers ──

let _host = null;
let _secret = null;

async function init() {
  _secret = resolveSecret();
  _host = await discoverOrchestrator();
  if (!_host) {
    console.error('error: could not find orchestrator (tried Docker discovery + localhost:3000/3001)');
    console.error('  set ORCHESTRATOR_URL or start the orchestrator first');
    process.exit(1);
  }
}

function headers() {
  const h = { 'content-type': 'application/json' };
  if (_secret) h['authorization'] = `Bearer ${_secret}`;
  return h;
}

async function api(method, path, body) {
  const opts = { method, headers: headers() };
  if (body !== undefined) opts.body = JSON.stringify(body);
  const resp = await fetch(`${_host}${path}`, opts);
  const text = await resp.text();
  let data;
  try { data = JSON.parse(text); } catch { data = text; }
  if (!resp.ok) {
    const msg = typeof data === 'object' ? data.error || JSON.stringify(data) : data;
    console.error(`error: ${resp.status} ${msg}`);
    process.exit(1);
  }
  return data;
}

/**
 * Upload a file to the orchestrator and return the file record.
 * @param {string} filePath - Path to the file to upload
 * @returns {Promise<{id: string, name: string, size: number}>}
 */
async function uploadFile(filePath) {
  const resolvedPath = resolve(filePath);
  if (!existsSync(resolvedPath)) {
    console.error(`error: file not found: ${filePath}`);
    process.exit(1);
  }
  const content = readFileSync(resolvedPath);
  const filename = basename(resolvedPath);
  const h = headers();
  h['content-type'] = 'application/octet-stream';
  const resp = await fetch(`${_host}/api/files?filename=${encodeURIComponent(filename)}`, {
    method: 'POST',
    headers: h,
    body: content,
  });
  const data = await resp.json();
  if (!resp.ok) {
    console.error(`error uploading ${filename}: ${data.error || resp.status}`);
    process.exit(1);
  }
  return data;
}

function agentName() {
  return process.env['COLLAB_AGENT'] || null;
}

function requireAgentName(explicit) {
  const name = explicit || agentName();
  if (!name) {
    console.error('error: agent name required (pass as argument or set COLLAB_AGENT)');
    process.exit(1);
  }
  return name;
}

// ── Commands ──

const COMMANDS = {};

// `mode` controls help visibility:
//   'both'       — visible in both persistent and ephemeral help (default)
//   'persistent' — visible only when the CLI is NOT in ephemeral mode
//   'ephemeral'  — visible only when the CLI IS in ephemeral mode
// Mode never gates execution — `complete`/`fail` still error cleanly via
// `requireEphemeralEnv()` if invoked outside an ephemeral context. The mode
// tag only controls what `collab --help` lists.
function cmd(name, usage, desc, fn, mode = 'both') {
  COMMANDS[name] = { usage, desc, fn, mode };
}

function formatReplyContext(message, inReplyTo) {
  return inReplyTo ? `In reply to: ${inReplyTo}\n\n${message}` : message;
}

function parseSendArgs(args, implicitTarget = null) {
  let topic = null;
  let replyReminder = null;
  let inReplyTo = null;
  let notify = null;
  const files = [];
  const target = implicitTarget ?? args[0];
  const positional = [];
  const startIdx = implicitTarget ? 0 : 1;

  for (let i = startIdx; i < args.length; i++) {
    if (args[i] === '--topic' && args[i + 1]) { topic = args[++i]; }
    else if (args[i] === '--in-reply-to' && args[i + 1]) { inReplyTo = args[++i]; }
    else if (args[i] === '--file' && args[i + 1]) { files.push(args[++i]); }
    else if (args[i] === '--notify') {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { notify = args[++i]; }
      else { notify = 'normal'; }
    }
    else if (args[i] === '--reply-reminder') {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { replyReminder = parseInt(args[++i], 10); }
      else { replyReminder = 30; }
    }
    else { positional.push(args[i]); }
  }

  return {
    target,
    topic,
    replyReminder,
    inReplyTo,
    notify,
    files,
    message: positional.join(' '),
  };
}

// `telegram:<name>` (with a name) is NO LONGER resolved here — it routes through
// /api/agents/send so the orchestrator disambiguates agent-bot vs destination
// (RFC-008 PR-D). This helper only resolves BARE `telegram` (no name → the
// default/first enabled telegram destination), preserving the legacy shorthand.
async function resolveDefaultTelegramDestination(target) {
  if (target === 'telegram') {
    const dests = await api('GET', '/api/destinations');
    const match = dests.find(d => d.type === 'telegram' && d.enabled);
    if (match) return match.name;
    console.error('error: no enabled telegram destination found');
    process.exit(1);
  }
  return null;
}

/** True for a `telegram:<name>` target (with a non-empty name). */
function isTelegramAgentTarget(target) {
  const colonIdx = target.indexOf(':');
  if (colonIdx <= 0) return false;
  return target.slice(0, colonIdx) === 'telegram' && target.slice(colonIdx + 1).length > 0;
}

async function dispatchSend({ target, topic, message, replyReminder, inReplyTo, notify, files }) {
  // Upload any attached files first
  const fileIds = [];
  if (files && files.length > 0) {
    for (const filePath of files) {
      const result = await uploadFile(filePath);
      fileIds.push(result.id);
      console.log(`uploaded: ${result.name} (${result.id})`);
    }
  }

  // Per-agent telegram outbound (RFC-008 PR-D): "telegram:<name>" routes through
  // /api/agents/send so the orchestrator picks the agent-bot path (replying to
  // the originating chat) and falls back to a same-named destination otherwise.
  if (isTelegramAgentTarget(target)) {
    if (!message && fileIds.length === 0) {
      console.error('usage: collab send telegram:<agent> "message"');
      process.exit(1);
    }
    const formattedMessage = formatReplyContext(message || '(file attachment)', inReplyTo);
    const from = requireAgentName();
    // /api/agents/send requires a topic; default to 'telegram' for the round-trip
    // reply when the caller did not pass one.
    await api('POST', '/api/agents/send', {
      from,
      to: target,
      message: formattedMessage,
      topic: topic || 'telegram',
    });
    console.log('sent to telegram');
    if (notify) {
      await api('POST', '/api/notify', { agent: from, message: formattedMessage, priority: notify }).catch(() => {});
    }
    return;
  }

  // Bare-`telegram` destination shorthand: "telegram" → default telegram dest.
  const destName = await resolveDefaultTelegramDestination(target);
  if (destName) {
    if (!message && fileIds.length === 0) {
      console.error('usage: collab send telegram "message"');
      process.exit(1);
    }
    const formattedMessage = formatReplyContext(message || '(file attachment)', inReplyTo);
    const fromAgent = agentName() || undefined;
    await api('POST', `/api/destinations/${encodeURIComponent(destName)}/send`, {
      message: formattedMessage,
      fromAgent,
    });
    console.log('sent to telegram');
    if (notify) {
      const fromAgent = agentName() || undefined;
      await api('POST', '/api/notify', { agent: fromAgent, message: formattedMessage, priority: notify }).catch(() => {});
    }
    return;
  }

  if (!target || !topic || (!message && fileIds.length === 0)) {
    console.error('usage: collab send <target> --topic <topic> [--file <path>] [--in-reply-to <text>] [--notify [priority]] <message>');
    process.exit(1);
  }

  // Validate target before sending.
  // Address-prefixed targets (agent:/topic:/approval:) bypass the bare-name check.
  // Bare names continue to be validated against /api/agents.
  if (target !== 'operator' && target !== 'dashboard' && !target.includes(':')) {
    const agents = await api('GET', '/api/agents');
    const agentNames = agents.map(a => a.name);
    if (!agentNames.includes(target)) {
      console.error(`error: unknown target "${target}"`);
      console.error(`valid targets: operator, dashboard, agent:<name>, topic:<tmpl>/<name>, approval:<channel>, ${agentNames.join(', ')}`);
      process.exit(1);
    }
  }

  const formattedMessage = formatReplyContext(message || '(file attachment)', inReplyTo);
  if (target === 'operator' || target === 'dashboard') {
    if (replyReminder) {
      console.error('error: --reply-reminder is only supported when messaging another agent');
      process.exit(1);
    }
    const agent = requireAgentName();
    const body = { agent, message: formattedMessage, topic };
    if (fileIds.length > 0) body.fileIds = fileIds;
    await api('POST', '/api/dashboard/reply', body);
    console.log('sent');
    if (notify) {
      await api('POST', '/api/notify', { agent, message: formattedMessage, priority: notify }).catch(() => {});
    }
    return;
  }

  const from = requireAgentName();
  const body = { from, to: target, message: formattedMessage, topic };
  if (replyReminder) body.replyReminder = replyReminder;
  if (fileIds.length > 0) body.fileIds = fileIds;
  const data = await api('POST', '/api/agents/send', body);
  console.log(`queued (id:${data.queueId})`);

  // Fire notification after normal send if --notify was passed
  if (notify) {
    const agent = agentName() || undefined;
    await api('POST', '/api/notify', { agent, message: formattedMessage, priority: notify }).catch(() => {});
  }
}

cmd('agents', 'agents', 'List all agents', async () => {
  const agents = await api('GET', '/api/agents');
  if (agents.length === 0) { console.log('No agents'); return; }
  const maxName = Math.max(...agents.map(a => a.name.length), 4);
  for (const a of agents) {
    const ctx = a.lastContextPct != null ? `${a.lastContextPct}%` : '--';
    console.log(
      `${a.name.padEnd(maxName)}  ${a.state.padEnd(10)}  ${a.engine.padEnd(8)}  ctx:${ctx}`
    );
  }
});

COMMANDS['list-agents'] = {
  ...COMMANDS['agents'],
  usage: 'list-agents',
  desc: 'List all agents',
};

cmd('status', 'status', 'Orchestrator status', async () => {
  const s = await api('GET', '/api/orchestrator/status');
  console.log(`agents: ${s.totalAgents}  proxies: ${s.totalProxies}`);
  if (s.byState && Object.keys(s.byState).length > 0) {
    console.log(`  ${Object.entries(s.byState).map(([k, v]) => `${k}:${v}`).join('  ')}`);
  }
});

cmd('send', 'send <target> --topic <topic> [--file <path>]... [--in-reply-to <text>] [--notify [priority]] <message>', 'Send a message to operator or another agent', async (args) => {
  await dispatchSend(parseSendArgs(args));
});

cmd('reply', 'reply --topic <topic> [--in-reply-to <text>] <message>', 'Compatibility alias for send operator', async (args) => {
  await dispatchSend(parseSendArgs(args, 'operator'));
});

// ── v3 Q3: ephemeral instance signaling ──────────────────────────────────
//
// Used inside an ephemeral agent's tmux session. The orchestrator injects
// the env contract (MESSAGE_ID, REPLY_PATH, STATUS_PATH, INSTANCE_ID, ...)
// via `tmux set-environment` before pasting the `start` hook. Both
// subcommands:
//   1. Validate the env trio is present (otherwise the agent is in persistent
//      mode and shouldn't be calling these).
//   2. Atomically write $REPLY_PATH and $STATUS_PATH (tmp + rename) so the
//      reaper's `statSync(...).size === 0` in-progress check is reliable.
//   3. POST /api/instances/$INSTANCE_ID/complete to wake the reaper. If the
//      POST fails, the reaper picks the instance up on its next sweep.
// Both are idempotent — a second call is a no-op (409 from the orchestrator).

function requireEphemeralEnv() {
  const messageId = process.env['MESSAGE_ID'];
  const replyPath = process.env['REPLY_PATH'];
  const statusPath = process.env['STATUS_PATH'];
  const instanceId = process.env['INSTANCE_ID'];
  if (!messageId || !replyPath || !statusPath || !instanceId) {
    console.error('error: `collab complete`/`fail` require ephemeral env vars');
    console.error('  MESSAGE_ID, REPLY_PATH, STATUS_PATH, INSTANCE_ID must all be set');
    console.error('  these are injected by the orchestrator on ephemeral spawn');
    process.exit(1);
  }
  return { messageId, replyPath, statusPath, instanceId };
}

function atomicWrite(path, content) {
  mkdirSync(dirname(path), { recursive: true });
  const tmp = `${path}.tmp-${process.pid}-${Date.now()}`;
  writeFileSync(tmp, content);
  renameSync(tmp, path);
}

cmd('complete', 'complete --reply <json>', 'Ephemeral: signal success and reply', async (args) => {
  let reply = null;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--reply' && args[i + 1]) { reply = args[++i]; }
  }
  if (reply === null) {
    console.error('usage: collab complete --reply <json>');
    process.exit(1);
  }
  const { instanceId, replyPath, statusPath } = requireEphemeralEnv();
  atomicWrite(replyPath, reply);
  atomicWrite(statusPath, 'ok\n');
  // Best-effort wake — if the orchestrator is unreachable, the reaper will
  // pick this up on its next sweep anyway.
  try {
    await init();
    const resp = await fetch(`${_host}/api/instances/${encodeURIComponent(instanceId)}/complete`, {
      method: 'POST',
      headers: headers(),
    });
    if (resp.status === 409) {
      console.log('already completed');
      return;
    }
    if (!resp.ok) {
      console.warn(`warning: completion POST returned ${resp.status} — reaper will retry`);
    }
    console.log('completed');
  } catch (err) {
    console.warn(`warning: completion POST failed (${err.message}) — reaper will retry`);
  }
}, 'ephemeral');

cmd('fail', 'fail --reason <text>', 'Ephemeral: signal failure', async (args) => {
  let reason = null;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--reason' && args[i + 1]) { reason = args[++i]; }
  }
  if (reason === null) {
    console.error('usage: collab fail --reason <text>');
    process.exit(1);
  }
  const { instanceId, statusPath } = requireEphemeralEnv();
  atomicWrite(statusPath, `error\n${reason}\n`);
  try {
    await init();
    const resp = await fetch(`${_host}/api/instances/${encodeURIComponent(instanceId)}/complete`, {
      method: 'POST',
      headers: headers(),
    });
    if (resp.status === 409) {
      console.log('already failed');
      return;
    }
    if (!resp.ok) {
      console.warn(`warning: failure POST returned ${resp.status} — reaper will retry`);
    }
    console.log('failed');
  } catch (err) {
    console.warn(`warning: failure POST failed (${err.message}) — reaper will retry`);
  }
}, 'ephemeral');

// ── v3 Q5: approvals CRUD subcommands ────────────────────────────────────
//
// Wraps the orchestrator's REST surface. The requester address defaults to
// $COLLAB_AGENT (injected by the orchestrator) and falls back to "dashboard"
// when run from the host. Subcommand dispatch lives inside the `approval`
// command so the help banner only shows one line.

function approvalRequester() {
  return process.env['COLLAB_AGENT'] || 'dashboard';
}

function parseApprovalFlags(args, schema) {
  const result = {};
  const positional = [];
  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg.startsWith('--')) {
      const key = arg.slice(2);
      if (schema[key] && args[i + 1] !== undefined) {
        result[key] = args[++i];
      } else if (schema[key] === 'bool') {
        result[key] = true;
      }
    } else {
      positional.push(arg);
    }
  }
  return { flags: result, positional };
}

async function approvalCreate(args) {
  const { flags } = parseApprovalFlags(args, { channel: true, payload: true, requester: true });
  if (!flags.channel) {
    console.error('usage: collab approval create --channel <c> [--payload <json>] [--requester <addr>]');
    console.error('  --payload defaults to "{}" when omitted');
    process.exit(1);
  }
  const payload = flags.payload ?? '{}';
  const body = {
    requesterAddr: flags.requester || approvalRequester(),
    channel: flags.channel,
    payload,
  };
  const data = await api('POST', '/api/approvals', body);
  console.log(data.id);
}

async function approvalGet(args) {
  const id = args[0];
  if (!id) {
    console.error('usage: collab approval get <id>');
    process.exit(1);
  }
  const data = await api('GET', `/api/approvals/${encodeURIComponent(id)}`);
  console.log(JSON.stringify(data, null, 2));
}

async function approvalSet(args) {
  const id = args[0];
  const rest = args.slice(1);
  const { flags } = parseApprovalFlags(rest, { state: true, payload: true, 'decided-by': true });
  if (!id || !flags.state) {
    console.error('usage: collab approval set <id> --state approved|rejected|amended [--payload <json>] [--decided-by <name>]');
    process.exit(1);
  }
  const body = { state: flags.state };
  if (flags.payload !== undefined) body.payload = flags.payload;
  if (flags['decided-by']) body.decidedBy = flags['decided-by'];
  const data = await api('POST', `/api/approvals/${encodeURIComponent(id)}/set`, body);
  console.log(JSON.stringify(data, null, 2));
}

async function approvalWithdraw(args) {
  const id = args[0];
  if (!id) {
    console.error('usage: collab approval withdraw <id> [--requester <addr>]');
    process.exit(1);
  }
  const { flags } = parseApprovalFlags(args.slice(1), { requester: true });
  const body = { requesterAddr: flags.requester || approvalRequester() };
  const data = await api('POST', `/api/approvals/${encodeURIComponent(id)}/withdraw`, body);
  console.log(JSON.stringify(data, null, 2));
}

async function approvalAwait(args) {
  const id = args[0];
  if (!id) {
    console.error('usage: collab approval await <id> [--timeout <ms>] [--interval <ms>]');
    console.error('  --timeout   max wait in ms; default 600000 (10 minutes); exits non-zero on timeout');
    console.error('  --interval  poll interval in ms; default 500');
    process.exit(1);
  }
  const { flags } = parseApprovalFlags(args.slice(1), { timeout: true, interval: true });
  // Defaults: 10 minute timeout, 500ms poll interval. Plain client-side
  // polling per the v3 spec — the server's /await endpoint is a single
  // non-blocking read, so the CLI is the source of truth for cadence.
  const totalTimeoutMs = flags.timeout ? parseInt(flags.timeout, 10) : 600_000;
  const intervalMs = flags.interval ? parseInt(flags.interval, 10) : 500;
  const deadline = Date.now() + totalTimeoutMs;
  for (;;) {
    const row = await api('GET', `/api/approvals/${encodeURIComponent(id)}`);
    if (row.state && row.state !== 'pending') {
      console.log(JSON.stringify(row, null, 2));
      return;
    }
    if (Date.now() >= deadline) {
      console.error(`timeout: approval ${id} still pending after ${totalTimeoutMs}ms`);
      process.exit(2);
    }
    await new Promise((r) => setTimeout(r, intervalMs));
  }
}

async function approvalList(args) {
  // Both --channel and --state are optional; the server AND's them when
  // present and returns the cross-channel feed when both are omitted.
  const { flags } = parseApprovalFlags(args, { channel: true, state: true });
  const qs = new URLSearchParams();
  if (flags.channel) qs.set('channel', flags.channel);
  if (flags.state) qs.set('state', flags.state);
  const path = qs.toString() ? `/api/approvals?${qs.toString()}` : '/api/approvals';
  const data = await api('GET', path);
  console.log(JSON.stringify(data, null, 2));
}

cmd('approval', 'approval <create|get|set|withdraw|await|list> [args...]', 'Manage approval records', async (args) => {
  const sub = args[0];
  const rest = args.slice(1);
  switch (sub) {
    case 'create':   return approvalCreate(rest);
    case 'get':      return approvalGet(rest);
    case 'set':      return approvalSet(rest);
    case 'withdraw': return approvalWithdraw(rest);
    case 'await':    return approvalAwait(rest);
    case 'list':     return approvalList(rest);
    default:
      console.error('usage: collab approval <create|get|set|withdraw|await|list> [args...]');
      console.error('  create --channel <c> [--payload <json>]      (payload defaults to "{}")');
      console.error('  get <id>');
      console.error('  set <id> --state <approved|rejected|amended> [--payload <json>]');
      console.error('  withdraw <id>');
      console.error('  await <id> [--timeout <ms>] [--interval <ms>] (timeout defaults to 600000 ms)');
      console.error('  list [--channel <c>] [--state <s>]');
      process.exit(1);
  }
});

cmd('spawn', 'spawn <name> [task...]', 'Spawn an agent', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab spawn <name> [task...]'); process.exit(1); }
  const task = args.slice(1).join(' ') || undefined;
  const data = await api('POST', `/api/agents/${encodeURIComponent(name)}/spawn`, { task });
  console.log(`${data.name} → ${data.state}`);
});

cmd('create', 'create <name> <engine> <cwd>', 'Create a new agent', async (args) => {
  const [name, engine, cwd] = args;
  if (!name || !engine || !cwd) { console.error('usage: collab create <name> <engine> <cwd>'); process.exit(1); }
  const data = await api('POST', '/api/agents', { name, engine, cwd });
  console.log(`created ${data.name} (${data.engine})`);
});

cmd('create-agent', 'create-agent <persona-file>', 'Create or update an agent from a persona file', async (args) => {
  const personaFile = args[0];
  if (!personaFile) {
    console.error('usage: collab create-agent <persona-file>');
    process.exit(1);
  }
  const filePath = resolve(personaFile);
  if (!existsSync(filePath)) {
    console.error(`error: persona file not found: ${filePath}`);
    process.exit(1);
  }
  const content = readFileSync(filePath, 'utf-8');
  if (!content.trim()) {
    console.error(`error: persona file is empty: ${filePath}`);
    process.exit(1);
  }
  const name = basename(filePath).replace(/\.md$/i, '');
  const data = await api('POST', '/api/personas', { name, content });
  console.log(`materialized ${data.agent.name} from ${basename(filePath)}`);
});

cmd('exit', 'exit <name>', 'Exit an agent (suspend)', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab exit <name>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/exit`);
  console.log(`${name} exited`);
});
// Hidden backward-compat alias
COMMANDS['suspend'] = { ...COMMANDS['exit'], hidden: true };

