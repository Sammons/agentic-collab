cmd('tmux', 'tmux <agent> -- <tmux args...>', 'Run a constrained tmux command against an agent session', async (args) => {
  const name = args[0];
  const dashIdx = args.indexOf('--');
  const tmuxArgs = dashIdx === -1 ? args.slice(1) : args.slice(dashIdx + 1);
  if (!name || tmuxArgs.length === 0) {
    console.error('usage: collab tmux <agent> -- <tmux args...>');
    process.exit(1);
  }
  const data = await api('POST', `/api/agents/${encodeURIComponent(name)}/tmux`, { args: tmuxArgs });
  if (data.data == null) {
    console.log('ok');
  } else if (typeof data.data === 'string') {
    console.log(data.data);
  } else if (typeof data.data === 'number' || typeof data.data === 'boolean') {
    console.log(String(data.data));
  } else {
    console.log(JSON.stringify(data.data, null, 2));
  }
});

// ── Reminders ──

cmd('reminder', 'reminder <sub> [args...]', 'Manage reminders (add|list|done|cancel|swap)', async (args) => {
  const sub = args[0];
  const sargs = args.slice(1);

  if (sub === 'add') {
    // collab reminder add <agent> "<prompt>" --cadence 10m [--from <name>]
    let cadence = null, from = null;
    const positional = [];
    for (let i = 0; i < sargs.length; i++) {
      if (sargs[i] === '--cadence' && sargs[i + 1]) { cadence = sargs[++i]; }
      else if (sargs[i] === '--from' && sargs[i + 1]) { from = sargs[++i]; }
      else { positional.push(sargs[i]); }
    }
    const targetAgent = positional[0];
    const prompt = positional.slice(1).join(' ');
    if (!targetAgent || !prompt) {
      console.error('usage: collab reminder add <agent> "<prompt>" --cadence 10m [--from <name>]');
      process.exit(1);
    }
    // parse cadence: "10m" → 10, "30m" → 30, bare number → minutes
    let cadenceMinutes = 30;
    if (cadence) {
      const m = cadence.match(/^(\d+)m?$/);
      if (!m) { console.error('error: --cadence must be like 10m or 30'); process.exit(1); }
      cadenceMinutes = parseInt(m[1], 10);
    }
    if (cadenceMinutes < 5) { console.error('error: cadence must be >= 5 minutes'); process.exit(1); }
    const createdBy = from || agentName() || undefined;
    const reminder = await api('POST', '/api/reminders', { agentName: targetAgent, prompt, cadenceMinutes, createdBy });
    console.log(`created reminder #${reminder.id} for ${targetAgent} (every ${cadenceMinutes}m)`);
  }

  else if (sub === 'list') {
    // collab reminder list [--agent <name>]
    let agent = null;
    for (let i = 0; i < sargs.length; i++) {
      if (sargs[i] === '--agent' && sargs[i + 1]) { agent = sargs[++i]; }
    }
    const query = agent ? `?agent=${encodeURIComponent(agent)}` : '';
    const reminders = await api('GET', `/api/reminders${query}`);
    if (reminders.length === 0) { console.log('No reminders'); return; }
    const pending = reminders.filter(r => r.status === 'pending');
    const completed = reminders.filter(r => r.status === 'completed');
    const maxId = Math.max(...reminders.map(r => r.id.toString().length), 2);
    const maxAgent = Math.max(...reminders.map(r => r.agentName.length), 5);
    const maxPrompt = Math.min(Math.max(...reminders.map(r => r.prompt.length), 6), 50);

    const printRows = (title, rows) => {
      if (rows.length === 0) return;
      if (title) console.log(title);
      console.log(`${'ID'.padEnd(maxId)}  ${'Agent'.padEnd(maxAgent)}  ${'Prompt'.padEnd(maxPrompt)}  Cadence   Status`);
      for (const r of rows) {
        const prompt = r.prompt.length > 50 ? r.prompt.slice(0, 47) + '...' : r.prompt;
        const cadence = `${r.cadenceMinutes}m`.padEnd(9);
        const status = r.status === 'completed' ? 'done' : 'pending';
        console.log(`${r.id.toString().padEnd(maxId)}  ${r.agentName.padEnd(maxAgent)}  ${prompt.padEnd(maxPrompt)}  ${cadence} ${status}`);
      }
    };

    printRows('', pending);
    if (completed.length > 0) {
      if (pending.length > 0) console.log('');
      printRows('Recently completed', completed);
    }
  }

  else if (sub === 'done') {
    // collab reminder done <id>
    const id = parseInt(sargs[0], 10);
    if (isNaN(id)) { console.error('usage: collab reminder done <id>'); process.exit(1); }
    await api('POST', `/api/reminders/${id}/complete`);
    console.log(`reminder #${id} completed`);
  }

  else if (sub === 'cancel') {
    // collab reminder cancel <id>
    const id = parseInt(sargs[0], 10);
    if (isNaN(id)) { console.error('usage: collab reminder cancel <id>'); process.exit(1); }
    await api('DELETE', `/api/reminders/${id}`);
    console.log(`reminder #${id} cancelled`);
  }

  else if (sub === 'swap') {
    // collab reminder swap <id1> <id2>
    const id1 = parseInt(sargs[0], 10);
    const id2 = parseInt(sargs[1], 10);
    if (isNaN(id1) || isNaN(id2)) { console.error('usage: collab reminder swap <id1> <id2>'); process.exit(1); }
    await api('POST', '/api/reminders/swap', { id1, id2 });
    console.log(`swapped reminder #${id1} ↔ #${id2}`);
  }

  else {
    console.error(`unknown subcommand: ${sub}`);
    console.error('usage: collab reminder {add|list|done|cancel|swap}');
    process.exit(1);
  }
});

// ── Pages ──

const templatesDir = join(new URL('.', import.meta.url).pathname, '..', 'src', 'templates');

function publishTar(dirPath) {
  return execSync(`tar cf - -C ${JSON.stringify(dirPath)} .`, { maxBuffer: 50 * 1024 * 1024 });
}

async function uploadTar(slug, tarData) {
  const agent = process.env['COLLAB_AGENT'] ?? null;
  const qs = `slug=${encodeURIComponent(slug)}${agent ? '&agent=' + encodeURIComponent(agent) : ''}`;
  const h = { 'Content-Type': 'application/x-tar' };
  if (_secret) h['Authorization'] = `Bearer ${_secret}`;
  const res = await fetch(`${_host}/api/pages?${qs}`, {
    method: 'POST',
    headers: h,
    body: tarData,
  });
  const body = await res.json();
  if (!res.ok) { console.error(body.error ?? 'Publish failed'); process.exit(1); }
  console.log(`published: ${_host}/pages/${slug} (${body.fileCount} files, ${body.totalBytes} bytes)`);
}

cmd('publish', 'collab publish <slug> <dir> [--template <name> --store <store> --title <title>]', 'Publish a directory or template as a page', async (args) => {
  let slug = null;
  let dir = null;
  let template = null;
  let store = null;
  let title = null;

  // Parse flags and positional args
  const positional = [];
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--template' && args[i + 1]) { template = args[++i]; }
    else if (args[i] === '--store' && args[i + 1]) { store = args[++i]; }
    else if (args[i] === '--title' && args[i + 1]) { title = args[++i]; }
    else { positional.push(args[i]); }
  }

  slug = positional[0];
  dir = positional[1];

  if (!slug) {
    console.error('usage: collab publish <slug> <directory>');
    console.error('       collab publish <slug> --template <name> --store <store> --title <title>');
    process.exit(1);
  }

  if (template) {
    // Template-based publish
    if (!store) { console.error('error: --store is required when using --template'); process.exit(1); }
    if (!title) title = slug;

    const templatePath = join(templatesDir, `${template}.html`);
    if (!existsSync(templatePath)) {
      console.error(`error: template not found: ${template}`);
      console.error(`  looked at: ${templatePath}`);
      console.error(`  run 'collab templates' to see available templates`);
      process.exit(1);
    }

    let html = readFileSync(templatePath, 'utf-8');
    html = html.replaceAll('{{STORE}}', store);
    html = html.replaceAll('{{TITLE}}', title);
    html = html.replaceAll('{{TOKEN}}', _secret ?? '');

    const tmpDir = mkdtempSync(join(tmpdir(), 'collab-template-'));
    writeFileSync(join(tmpDir, 'index.html'), html);

    const tarData = publishTar(tmpDir);
    await uploadTar(slug, tarData);
  } else {
    // Directory-based publish (original flow)
    if (!dir) {
      console.error('usage: collab publish <slug> <directory>');
      console.error('       collab publish <slug> --template <name> --store <store> --title <title>');
      process.exit(1);
    }
    const resolved = resolve(dir);
    if (!existsSync(resolved)) {
      console.error(`directory not found: ${resolved}`);
      process.exit(1);
    }
    const tarData = publishTar(resolved);
    await uploadTar(slug, tarData);
  }
});

cmd('templates', 'collab templates', 'List available page templates', async () => {
  if (!existsSync(templatesDir)) {
    console.log('No templates directory found');
    return;
  }
  const files = readdirSync(templatesDir).filter(f => f.endsWith('.html')).sort();
  if (files.length === 0) {
    console.log('No templates available');
    return;
  }
  console.log('Available templates:\n');
  for (const f of files) {
    const name = f.replace(/\.html$/, '');
    console.log(`  ${name}`);
  }
  console.log(`\nUsage: collab publish <slug> --template <name> --store <store> --title <title>`);
});

cmd('pages', 'collab pages {list|delete}', 'Manage published pages', async (args) => {
  const sub = args[0];
  if (!sub || sub === 'list') {
    const pages = await api('GET', '/api/pages');
    if (!Array.isArray(pages) || pages.length === 0) { console.log('No published pages'); return; }
    for (const p of pages) {
      const size = p.totalBytes >= 1024 * 1024 ? (p.totalBytes / 1024 / 1024).toFixed(1) + 'MB' : (p.totalBytes / 1024).toFixed(0) + 'KB';
      console.log(`  ${p.slug.padEnd(30)} ${String(p.fileCount).padStart(4)} files  ${size.padStart(8)}  ${p.agent ?? '-'}  ${p.updatedAt}`);
    }
  } else if (sub === 'delete') {
    const slug = args[1];
    if (!slug) { console.error('usage: collab pages delete <slug>'); process.exit(1); }
    const h = {};
    if (_secret) h['Authorization'] = `Bearer ${_secret}`;
    const res = await fetch(`${_host}/api/pages/${encodeURIComponent(slug)}`, {
      method: 'DELETE',
      headers: h,
    });
    if (!res.ok) { const body = await res.json().catch(() => null); console.error(body?.error ?? 'Delete failed'); process.exit(1); }
    console.log(`deleted: ${slug}`);
  } else {
    console.error('usage: collab pages {list|delete <slug>}');
    process.exit(1);
  }
});

// ── Data Stores ──

cmd('db', 'collab db {create|query|schema|list|delete}', 'Manage agent data stores', async (args) => {
  const sub = args[0];

  if (sub === 'create') {
    const name = args[1];
    if (!name) { console.error('usage: collab db create <name>'); process.exit(1); }
    const agent = agentName() ?? undefined;
    const store = await api('POST', '/api/stores', { name, agent });
    console.log(`created store: ${store.name}`);
  }

  else if (sub === 'query') {
    const name = args[1];
    const sql = args.slice(2).join(' ');
    if (!name || !sql) { console.error('usage: collab db query <name> <sql>'); process.exit(1); }
    const result = await api('POST', `/api/stores/${encodeURIComponent(name)}/query`, { sql });
    console.log(JSON.stringify(result, null, 2));
  }

  else if (sub === 'schema') {
    const name = args[1];
    if (!name) { console.error('usage: collab db schema <name>'); process.exit(1); }
    const schema = await api('GET', `/api/stores/${encodeURIComponent(name)}/schema`);
    if (Object.keys(schema).length === 0) {
      console.log('No tables');
    } else {
      for (const [table, cols] of Object.entries(schema)) {
        console.log(`${table}:`);
        for (const col of cols) {
          const flags = [];
          if (col.pk) flags.push('PK');
          if (col.notnull) flags.push('NOT NULL');
          console.log(`  ${col.name} ${col.type}${flags.length ? ' (' + flags.join(', ') + ')' : ''}`);
        }
      }
    }
  }

  else if (!sub || sub === 'list') {
    const stores = await api('GET', '/api/stores');
    if (!Array.isArray(stores) || stores.length === 0) { console.log('No data stores'); return; }
    for (const s of stores) {
      console.log(`  ${s.name.padEnd(30)} ${(s.agent ?? '-').padEnd(20)}  ${s.updatedAt}`);
    }
  }

  else if (sub === 'delete') {
    const name = args[1];
    if (!name) { console.error('usage: collab db delete <name>'); process.exit(1); }
    await api('DELETE', `/api/stores/${encodeURIComponent(name)}`);
    console.log(`deleted store: ${name}`);
  }

  else {
    console.error(`unknown subcommand: ${sub}`);
    console.error('usage: collab db {create|query|schema|list|delete}');
    process.exit(1);
  }
});

// ── Destinations ���─

cmd('destinations', 'destinations {list|add|delete|test}', 'Manage notification destinations (telegram, etc.)', async (args) => {
  const sub = args[0];

  if (!sub || sub === 'list') {
    const dests = await api('GET', '/api/destinations');
    if (!Array.isArray(dests) || dests.length === 0) { console.log('No destinations'); return; }
    for (const d of dests) {
      const status = d.enabled ? 'enabled' : 'disabled';
      console.log(`  ${d.name.padEnd(20)} ${d.type.padEnd(12)} ${status.padEnd(10)}  ${d.updatedAt}`);
    }
  }

  else if (sub === 'add') {
    // collab destinations add <name> telegram --bot-token <token> --chat-id <id>
    const name = args[1];
    const type = args[2];
    if (!name || !type) {
      console.error('usage: collab destinations add <name> telegram --bot-token <token> --chat-id <id>');
      process.exit(1);
    }
    const config = {};
    for (let i = 3; i < args.length; i++) {
      if (args[i] === '--bot-token' && args[i + 1]) { config.botToken = args[++i]; }
      else if (args[i] === '--chat-id' && args[i + 1]) { config.chatId = args[++i]; }
    }
    if (type === 'telegram' && (!config.botToken || !config.chatId)) {
      console.error('error: telegram requires --bot-token and --chat-id');
      process.exit(1);
    }
    const dest = await api('POST', '/api/destinations', { name, type, config });
    console.log(`created destination: ${dest.name} (${dest.type})`);
  }

  else if (sub === 'delete') {
    const name = args[1];
    if (!name) { console.error('usage: collab destinations delete <name>'); process.exit(1); }
    await api('DELETE', `/api/destinations/${encodeURIComponent(name)}`);
    console.log(`deleted destination: ${name}`);
  }

  else if (sub === 'test') {
    const name = args[1];
    if (!name) { console.error('usage: collab destinations test <name>'); process.exit(1); }
    await api('POST', `/api/destinations/${encodeURIComponent(name)}/test`);
    console.log('test message sent');
  }

  else {
    console.error(`unknown subcommand: ${sub}`);
    console.error('usage: collab destinations {list|add|delete|test}');
    process.exit(1);
  }
});

// ── Main ──

function showHelp() {
  const ephemeral = isEphemeralMode();

  // Mode-specific banner: ephemeral agents are reminded they own exactly one
  // message and must finalise via `collab complete`/`fail`. Persistent agents
  // get their address and inbox guidance.
  if (ephemeral) {
    const messageId = process.env['MESSAGE_ID'];
    const agentTemplate = process.env['AGENT_TEMPLATE'];
    const topicName = process.env['TOPIC_NAME'] ?? '<unknown>';
    console.log(`You are handling message ${messageId} on topic ${agentTemplate}/${topicName}. Call \`collab complete --reply '<json>'\` when done, or \`collab fail --reason <text>\` to signal failure.\n`);
  } else {
    const agent = process.env['COLLAB_AGENT'] ?? '<unset>';
    console.log(`Agent: ${agent}. Send messages with: \`collab send <target> --topic <t> <msg>\`. Inbox is delivered via tmux paste.\n`);
  }

  console.log('collab — CLI for agentic-collab orchestrator\n');
  console.log('Usage: collab <command> [args...]\n');
  console.log('Commands:');

  // Filter by mode: 'both' is always visible; 'ephemeral'-only commands hide
  // in persistent mode; 'persistent'-only commands hide in ephemeral mode.
  // Aliases inherit `mode` via object-spread at registration.
  const visible = Object.values(COMMANDS).filter(c => {
    if (c.hidden) return false;
    if (c.mode === 'both' || c.mode === undefined) return true;
    if (ephemeral) return c.mode === 'ephemeral';
    return c.mode === 'persistent';
  });
  const maxUsage = Math.max(...visible.map(c => c.usage.length));
  for (const c of visible) {
    console.log(`  ${c.usage.padEnd(maxUsage + 2)}  ${c.desc}`);
  }
  console.log('\nNotes:');
  console.log('  operator                The human operator in the dashboard');
  console.log('\nEnvironment:');
  console.log('  COLLAB_AGENT            Your agent name (auto-set by orchestrator)');
  console.log('  ORCHESTRATOR_URL        Override orchestrator URL');
  console.log('  ORCHESTRATOR_SECRET     Override secret');
}

[
  'status',
  'reply',
  'spawn',
  'create',
  'exit',
  'suspend',
  'resume',
  'interrupt',
  'compact',
  'kill',
  'destroy',
  'events',
  'reload',
].forEach((name) => {
  if (COMMANDS[name]) COMMANDS[name].hidden = true;
});

async function main() {
  const args = process.argv.slice(2);
  const command = args[0];

  if (!command || command === '--help' || command === '-h' || command === 'help') {
    showHelp();
    process.exit(0);
  }

  const handler = COMMANDS[command];
  if (!handler) {
    console.error(`unknown command: ${command}`);
    console.error(`run 'collab help' for usage`);
    process.exit(1);
  }

  await init();
  await handler.fn(args.slice(1));
}

main().catch((err) => {
  console.error(`error: ${err.message}`);
  process.exit(1);
});
