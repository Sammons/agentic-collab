cmd('reload', 'reload <name> [task...]', 'Reload an agent (kill + respawn)', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab reload <name> [task...]'); process.exit(1); }
  const task = args.slice(1).join(' ') || undefined;
  await api('POST', `/api/agents/${encodeURIComponent(name)}/reload`, { immediate: true, task });
  console.log(`${name} reloading`);
